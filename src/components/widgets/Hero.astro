---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = Astro.props.image ?? (await Astro.slots.render('image')),
  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative h-screen w-screen overflow-hidden" {...id ? { id } : {}}>
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>

    {
      image &&
        (typeof image === 'string' ? (
          <Fragment set:html={image} />
        ) : (
          <Image
            class="absolute h-full w-full object-cover"
            widths={[1024, 1440, 1920, 2400]}
            sizes="100vw"
            loading="eager"
            decoding="async"
            {...image}
          />
        ))
    }
  </div>

  <div class="relative h-full w-full">
    <div class="absolute bottom-8 left-8 md:bottom-[6vh] md:left-[3vw] max-w-4xl text-left">
      {
        tagline && (
          <p
            class="text-base text-secondary dark:text-blue-200 font-bold tracking-wide uppercase intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            set:html={tagline}
          />
        )
      }

      {
        title && (
          <h1
            class="text-5xl md:text-8xl font-bold leading-tighter tracking-tighter mb-8 font-heading text-white intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            set:html={title}
          />
        )
      }

      <div class="max-w-none">
        {
          subtitle && (
            <p
              class="font-normal text-xl text-slate-100 mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              set:html={subtitle}
            />
          )
        }

        {
          actions && (
            <div class="flex flex-nowrap flex-col sm:flex-row sm:justify-start gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              {Array.isArray(actions) ? (
                actions.map((action) => (
                  <div class="flex w-full sm:w-auto">
                    <Button {...(action || {})} class="w-full sm:mb-0 px-14 py-6" />
                  </div>
                ))
              ) : (
                <Fragment set:html={actions} />
              )}
            </div>
          )
        }
      </div>

      {content && <div class="mt-6">{<Fragment set:html={content} />}</div>}
    </div>
  </div>
</section>
